# =============================================================================
# Axis Agro Website — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Never commit .env.local to git.
# =============================================================================

# --- Supabase (required) ---
# From: Supabase Dashboard → Project Settings → API

# Public project URL (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose — protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SERVER ONLY — never expose to the browser)
# Used by the quote API route to insert submissions and send notifications
SUPABASE_SERVICE_ROLE_KEY=

# --- Site URL (required for production) ---
# Your live domain, e.g. https://axisagro.ng
# Used for sitemap, Open Graph metadata, and canonical URLs
NEXT_PUBLIC_SITE_URL=

# --- Farm location (required) ---
# Used by Contact page, Get a Quote map, Header "Visit Us" button, and directions links

# Latitude of the farm (decimal degrees)
NEXT_PUBLIC_FARM_LAT=

# Longitude of the farm (decimal degrees)
NEXT_PUBLIC_FARM_LNG=

# Full street address displayed on Contact and quote pages
NEXT_PUBLIC_FARM_ADDRESS=

# --- Google Maps (optional) ---
# Embed API key for interactive maps on Contact and Get a Quote pages
# Get from: https://console.cloud.google.com → APIs → Maps Embed API
# If omitted, a fallback Google Maps iframe is used
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# --- Email notifications (required for quote alerts) ---
# Resend API key — get from https://resend.com
RESEND_API_KEY=

# Email address that receives new quote request notifications
ADMIN_EMAIL=

# Sender address for notification emails (must be verified in Resend)
# Example: Axis Agro Website <notifications@axisagro.ng>
RESEND_FROM=

# =============================================================================
# Tauri / Atlas desktop app (optional — only needed for npm run tauri:dev)
# =============================================================================

# GROQ_API_KEY=
# GEMINI_API_KEY=
